#!/usr/bin/env bash
set -eo pipefail

if [[ $# -lt 1 ]]; then
    echo "Usage: atlas-restore <path_to_archive.gz> [target_uri]"
    echo "If target_uri is not provided, it will use ATLAS_URI from /etc/atlas-backup/backup.conf"
    exit 1
fi

ARCHIVE_FILE="$1"
TARGET_URI="$2"

if [[ ! -f "$ARCHIVE_FILE" ]]; then
    echo "Error: File not found: $ARCHIVE_FILE"
    exit 1
fi

if [[ -z "$TARGET_URI" ]]; then
    CONFIG_FILE="/etc/atlas-backup/backup.conf"
    if [[ -f "$CONFIG_FILE" ]]; then
        source "$CONFIG_FILE"
        TARGET_URI="$ATLAS_URI"
    else
        echo "Error: TARGET_URI not provided and config file not found."
        exit 1
    fi
fi

echo "WARNING: You are about to restore $ARCHIVE_FILE to the target database."
echo "This may overwrite existing data. Target URI: $(echo "$TARGET_URI" | sed 's/\(mongodb+srv:\/\/[^:]*:\)[^@]*@/\1****@/')"
read -p "Are you sure you want to proceed? (y/N): " confirm

if [[ "$confirm" =~ ^[Yy]$ ]]; then
    echo "Starting restore..."
    mongorestore --uri="$TARGET_URI" --archive="$ARCHIVE_FILE" --gzip --drop
    echo "Restore complete."
else
    echo "Restore aborted."
fi
