#!/usr/bin/env bash
set -eo pipefail

CONFIG_FILE="/etc/atlas-backup/backup.conf"
[[ ! -f "$CONFIG_FILE" ]] && CONFIG_FILE="./conf/backup.conf" # Fallback for local testing

if [[ ! -f "$CONFIG_FILE" ]]; then
    echo "Error: Configuration file not found."
    exit 1
fi

source "$CONFIG_FILE"

# Required variables
: "${ATLAS_URI:?ATLAS_URI must be set}"
: "${BACKUP_DIR:?BACKUP_DIR must be set}"
: "${STATE_FILE:=/var/lib/atlas-backup/checkpoint.json}"
: "${FULL_BACKUP_DAY:=0}" # Default Sunday

TIMESTAMP=$(date +"%Y%m%d_%H%M%S")
LOG_FILE="${BACKUP_DIR}/atlas_backup.log"
LOCK_FILE="/tmp/atlas-backup.lock"
mkdir -p "$BACKUP_DIR"

# Prevent overlapping runs
if [[ -f "$LOCK_FILE" ]] && kill -0 $(cat "$LOCK_FILE") 2>/dev/null; then
    log_msg "SKIP: Another backup process is already running."
    exit 0
fi
echo $$ > "$LOCK_FILE"
trap 'rm -f "$LOCK_FILE"' EXIT

log_msg() {
    echo "$(date +'%Y-%m-%d %H:%M:%S') - $1" | tee -a "$LOG_FILE"
}

notify() {
    local status="$1"
    local title="$2"
    local message="$3"
    [[ -z "$WEBHOOK_URL" ]] && return
    
    local color="36a64f" # Default Green
    case "$status" in
        "success") color="36a64f" ;;
        "failure") color="ff0000" ;;
        "info")    color="3498db" ;;
        "warning") color="f1c40f" ;;
    esac

    local payload=$(cat <<EOF
{
  "embeds": [{
    "title": "$title",
    "description": "$message",
    "color": $(printf '%d' "0x$color"),
    "timestamp": "$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  }]
}
EOF
)
    curl -s -X POST -H "Content-Type: application/json" -d "$payload" "$WEBHOOK_URL" > /dev/null
}

get_current_oplog_ts() {
    # Returns t:i format (e.g., 1713840000:1)
    mongosh "$ATLAS_URI" --quiet --eval 'let ts = db.getSiblingDB("local").oplog.rs.find().sort({$natural: -1}).limit(1).next().ts; print(ts.t + ":" + ts.i)' | tail -n 1
}

# Determine Strategy
DOW=$(date +%u) # 1-7 (Monday is 1)
[[ "$FULL_BACKUP_DAY" == "0" ]] && FULL_BACKUP_DAY=7 # Normalize Sunday to 7

MODE="incremental"
if [[ ! -f "$STATE_FILE" ]]; then
    MODE="full"
elif [[ "$DOW" -eq "$FULL_BACKUP_DAY" ]]; then
    # Only do full backup once per day
    LAST_FULL_TAG="${BACKUP_DIR}/.last_full_$(date +%Y%m%d)"
    if [[ ! -f "$LAST_FULL_TAG" ]]; then
        MODE="full"
    fi
fi

log_msg "Starting $MODE backup..."
notify "info" "🚀 Backup Started" "Mode: **$MODE**\nServer: \`$(hostname)\`"

if [[ "$MODE" == "full" ]]; then
    BACKUP_FILE="${BACKUP_DIR}/atlas_full_${TIMESTAMP}.archive.gz"
    if mongodump --uri="$ATLAS_URI" --archive="$BACKUP_FILE" --gzip --oplog; then
        FILE_SIZE=$(du -h "$BACKUP_FILE" | cut -f1)
        log_msg "Full backup completed: $BACKUP_FILE ($FILE_SIZE)"
        NEW_TS=$(get_current_oplog_ts)
        echo "$NEW_TS" > "$STATE_FILE"
        touch "${BACKUP_DIR}/.last_full_$(date +%Y%m%d)"
        notify "success" "✅ Full Backup Complete" "File: \`$(basename $BACKUP_FILE)\`\nSize: **$FILE_SIZE**"
    else
        log_msg "ERROR: Full backup failed."
        notify "failure" "❌ Full Backup Failed" "Host: \`$(hostname)\`\nCheck logs at: \`$LOG_FILE\`"
        exit 1
    fi
else
    # Incremental Mode
    LAST_TS=$(cat "$STATE_FILE")
    IFS=':' read -r T I <<< "$LAST_TS"
    
    BACKUP_FILE="${BACKUP_DIR}/atlas_incr_${TIMESTAMP}.oplog.bson.gz"
    QUERY="{\"ts\": {\"\$gt\": {\"\$timestamp\": {\"t\": $T, \"i\": $I}}}}"
    
    TEMP_DIR=$(mktemp -d)
    if mongodump --uri="$ATLAS_URI" --db local --collection oplog.rs --query "$QUERY" --out="$TEMP_DIR"; then
        if [[ -f "$TEMP_DIR/local/oplog.rs.bson" ]]; then
            gzip -c "$TEMP_DIR/local/oplog.rs.bson" > "$BACKUP_FILE"
            FILE_SIZE=$(du -h "$BACKUP_FILE" | cut -f1)
            log_msg "Incremental slice completed: $BACKUP_FILE ($FILE_SIZE)"
            NEW_TS=$(get_current_oplog_ts)
            echo "$NEW_TS" > "$STATE_FILE"
            notify "success" "🕒 Incremental Sync Complete" "File: \`$(basename $BACKUP_FILE)\`\nSize: **$FILE_SIZE**"
        else
            log_msg "WARNING: No new operations found in oplog since $LAST_TS."
            notify "info" "ℹ️ No changes" "No new operations to backup since $LAST_TS."
        fi
    else
        log_msg "ERROR: Incremental backup failed."
        notify "failure" "❌ Incremental Backup Failed" "Host: \`$(hostname)\`\nCheck logs at: \`$LOG_FILE\`"
        exit 1
    fi
    rm -rf "$TEMP_DIR"
fi

# Retention
if [[ -n "$RETENTION_DAYS" ]] && [[ "$RETENTION_DAYS" -gt 0 ]]; then
    find "$BACKUP_DIR" -type f -name "atlas_*.archive.gz" -mtime +${RETENTION_DAYS} -exec rm -f {} \;
    find "$BACKUP_DIR" -type f -name ".last_full_*" -mtime +1 -exec rm -f {} \;
fi
