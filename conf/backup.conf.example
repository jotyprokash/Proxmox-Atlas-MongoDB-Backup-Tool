# Atlas MongoDB Connection URI
ATLAS_URI="mongodb+srv://<USER>:<PASSWORD>@<CLUSTER_URL>/dt-mm-db"

# Local directory where backups will be stored
BACKUP_DIR="/var/lib/atlas-backup"

# Retention policy: Number of days to keep backups
RETENTION_DAYS=7

# Incremental Strategy
# Set FULL_BACKUP_DAY to 0-6 (0 is Sunday)
FULL_BACKUP_DAY=0
STATE_FILE="/var/lib/atlas-backup/checkpoint.json"

# Optional: Webhook URL for success/failure notifications
# WEBHOOK_URL="https://hc-ping.com/YOUR-UUID"
