# Atlas MongoDB Connection URI
# Example: mongodb+srv://backup_svc_account:PASSWORD@cluster0.abcde.mongodb.net/?retryWrites=true&w=majority
ATLAS_URI="mongodb+srv://<USER>:<PASSWORD>@<CLUSTER_URL>"

# Local directory where backups will be stored
BACKUP_DIR="/var/lib/atlas-backup"

# Retention policy: Number of days to keep backups
RETENTION_DAYS=7

# Optional: Webhook URL for success/failure notifications (Slack, Discord, Healthchecks.io)
# WEBHOOK_URL="https://hc-ping.com/YOUR-UUID"
